SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
OPENROUTER_API_KEY=your-openrouter-key
# Daily exam quotas by plan.
PER_USER_EXAM_LIMIT_FREE=3
PER_USER_EXAM_LIMIT_PRO=50
# Account-wide safety cap (USD): generation stops for the day once total spend hits this.
GLOBAL_DAILY_COST_LIMIT_USD=5.0
# Bootstrap allowlist: matching emails are promoted to app_users.is_admin=true.
# Authorization reads the DB flag; grant/revoke permanently via SQL if needed.
SUPER_ADMIN_EMAILS=you@example.com
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_FALLBACK_MODELS=qwen/qwen3-235b-a22b:free,mistralai/mistral-small-3.1-24b-instruct:free,google/gemma-3-27b-it:free,openrouter/free
# Paid models used only by Pro subscribers as fallbacks.
OPENROUTER_PAID_FALLBACK_MODELS=deepseek/deepseek-chat,google/gemini-2.0-flash-001
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=Exam Generator
ALLOWED_ORIGINS=http://localhost:5173
DOCUMENTS_BUCKET=documents
EXPORTS_BUCKET=exports
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Lemon Squeezy (leave blank for local/dev without billing).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=http://localhost:5173/pricing?checkout=success
BILLING_CANCEL_URL=http://localhost:5173/pricing?checkout=cancelled
